SESSION_SECRET=

# --- APIs externas ---
API_URL=
API_KEY=
WEBHOOK_SECRET=

# --- Servicios de terceros ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# --- Observabilidad ---
SENTRY_DSN=
DD_API_KEY=

# --- Feature flags ---
