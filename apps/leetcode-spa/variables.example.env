# ============================================================
# TEMPLATE DE VARIABLES DE ENTORNO — my-app
# ============================================================
# Este archivo es un TEMPLATE. No contiene valores reales.
# Los valores reales viven SOLO en Railway (Settings > Variables).
#
# Para cada ambiente, configurar estas variables directamente
# en el dashboard de Railway o mediante Railway CLI:
#   railway variables set KEY=value --environment <env>
#
# NUNCA commitear valores reales en este repositorio.
# ============================================================

# --- Aplicación ---
NODE_ENV=
PORT=
APP_URL=
LOG_LEVEL=

# --- Base de datos ---
